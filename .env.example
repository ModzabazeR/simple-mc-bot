# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=
DISCORD_NOTIFY_CHANNEL_ID=

# Minecraft server
MC_SERVER_DIR=/path/to/your/minecraft/server
MC_TMUX_SESSION=minecraft-server
MC_START_COMMAND=./start.sh
MC_HOST=localhost
MC_PORT=25565
MC_LOG_PATH=logs/latest.log

# Optional proxy/tunnel — leave MC_PROXY_TYPE empty to run without one.
# Supported types: playit
MC_PROXY_TYPE=
MC_PROXY_COMMAND=

# Seconds to wait after /stop before force-killing the tmux session.
# Set to 0 to disable force-kill (only send the graceful stop).
MC_STOP_TIMEOUT=60

# Comma-separated Discord user IDs allowed to /start and /stop.
# Leave empty to allow anyone in the server.
MC_ALLOWED_USER_IDS=
